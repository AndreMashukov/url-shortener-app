{
  "name": "url-shortener-redirect-bff",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "url-shortener-redirect-bff/src",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "url-shortener-redirect-bff"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "serverless package --stage dev --region ap-southeast-1",
        "cwd": "url-shortener-redirect-bff"
      }
    },
    "info": {
      "executor": "nx:run-commands",
      "options": {
        "command": "serverless info --stage dev --region ap-southeast-1",
        "cwd": "url-shortener-redirect-bff"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "serverless deploy --stage dev --region ap-southeast-1",
        "cwd": "url-shortener-redirect-bff"
      }
    }
  }
}